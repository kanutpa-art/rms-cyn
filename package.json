{
  "name": "rms-line-dormitory",
  "version": "1.0.0",
  "description": "LINE-First Dormitory Management System",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/assets/css/app.min.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./public/assets/css/app.min.css --watch",
    "build": "npm run build:css",
    "postinstall": "npm run build:css || echo 'CSS build skipped (will run on first request)'",
    "start": "node scripts/seed.js && node server.js",
    "dev": "nodemon server.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.4.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.18.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19"
  }
}
