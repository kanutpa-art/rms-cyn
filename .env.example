# ============================================================
# RMS — LINE-First Dormitory Management System
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# ============================================================
# Public URLs (used to build invite links, share URLs, webhook URLs)
# ============================================================
# BASE_PATH: subpath prefix when hosted under a path (e.g. /RMS for cyn-jewelry.com/RMS)
# Leave empty if hosted at domain root.
BASE_PATH=

# BASE_URL: full public URL where users access the app (NO trailing slash)
# - Production behind reverse proxy: https://cyn-jewelry.com/RMS
# - Local dev: http://localhost:3000
# When unset, the app derives URL from request headers (x-forwarded-host, etc.)
# combined with BASE_PATH, falling back to localhost:PORT.
BASE_URL=http://localhost:3000

# Session (เปลี่ยนให้เป็น random string ยาวๆ)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ============================================================
# LINE Developer Console — https://developers.line.biz
# ============================================================

# LINE Messaging API (1 channel ต่อ 1 หอพัก)
LINE_CHANNEL_ID=1234567890
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here

# LINE Login Channel (ใช้สำหรับ LIFF + OAuth)
LINE_LOGIN_CHANNEL_ID=1234567890
LINE_LOGIN_CHANNEL_SECRET=your_login_channel_secret

# LIFF ID (สร้างใน LINE Login Channel → LIFF tab)
LIFF_ID=1234567890-xxxxxxxx
LIFF_BASE_URL=https://liff.line.me/1234567890-xxxxxxxx

# ============================================================
# AI Chatbot (ฟรี — https://aistudio.google.com/app/apikey)
# ถ้าไม่กรอก ระบบจะใช้ rule-based แทน
# ============================================================
GEMINI_API_KEY=AIzaSy...

# ============================================================
# Admin Default (ใช้ตอน seed ครั้งแรก)
# ============================================================
ADMIN_NAME=แอดมิน
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
DORMITORY_NAME=หอพักของฉัน
